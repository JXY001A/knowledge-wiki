# macOS
.DS_Store

# Obsidian (keep config, ignore personal data)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.obsidian/*.bak
.obsidian/plugins/*/data.json

# Node.js
node_modules/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/

# Frontend build output (deployed via rsync, not git)
web/build/

# Environment
.env

# Retrieval cache (索引不入 git，每台机器自己重建)
.cache/

# 助理/记忆数据（SQLite 二进制不入 git，通过 SQL dump 备份到 raw/assets/db-backup/）
wiki/.data/*.db
wiki/.data/*.db-wal
wiki/.data/*.db-shm
wiki/.data/*.json

# Temporary
*.tmp
*.bak