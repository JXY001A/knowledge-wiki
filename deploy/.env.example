# knowledge-wiki 环境变量模板
# 复制到 knowledge-wiki/.env 并填入实际值（.env 不会被 git 追踪）

WIKI_ROOT=/home/jxy001a1/code/knowledge-wiki

# 企业微信（从企业微信管理后台获取）
WECOM_TOKEN=
WECOM_AES_KEY=
WECOM_CORP_ID=
WECOM_SECRET=
WECOM_AGENT_ID=1000002

# MCP Server
MCP_HOST=127.0.0.1
MCP_PORT=9300

# Webhook（生产环境用 0.0.0.0 以接受外网请求，开发环境用 127.0.0.1）
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=9400

# DeepSeek API
DEEPSEEK_API_KEY=

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
